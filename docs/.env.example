# OCTAR Environment Configuration
# ===============================
#
# OCTAR runs with zero configuration — all values have sensible defaults.
# Copy this file to .env and adjust only what you need to override.
#
# All values can also be set as environment variables (OCTAR_ prefix).

# ── Logging ─────────────────────────────────────────────────────────────────
# OCTAR_LOG_LEVEL=info

# ── TCP Data Plane ──────────────────────────────────────────────────────────
# OCTAR_SERVER_HOST=0.0.0.0
# OCTAR_SERVER_PORT=7000
# OCTAR_SERVER_MAX_CONNECTIONS=10000
# OCTAR_SERVER_READ_TIMEOUT=30s
# OCTAR_SERVER_WRITE_TIMEOUT=10s
# OCTAR_SERVER_INFLIGHT_MAX_INFLIGHT=256
# OCTAR_SERVER_INFLIGHT_GLOBAL_MAX=10000

# ── HTTP Management API ─────────────────────────────────────────────────────
# OCTAR_API_HOST=0.0.0.0
# OCTAR_API_PORT=8080

# ── TLS (optional) ─────────────────────────────────────────────────────────
# OCTAR_SERVER_TLS_ENABLED=true
# OCTAR_SERVER_TLS_CERT_FILE=/certs/server.crt
# OCTAR_SERVER_TLS_KEY_FILE=/certs/server.key
# OCTAR_API_TLS_ENABLED=true
# OCTAR_API_TLS_CERT_FILE=/certs/api.crt
# OCTAR_API_TLS_KEY_FILE=/certs/api.key

# ── Observability ───────────────────────────────────────────────────────────
# OCTAR_METRICS_ENABLED=true
# OCTAR_METRICS_PORT=2112
# OCTAR_PPROF_ENABLED=true
# OCTAR_PPROF_PORT=6060

# ── Default Admin User ──────────────────────────────────────────────────────
# If not set, a random password is generated and saved to data/admin_credentials.txt
# OCTAR_AUTH_DEFAULT_ADMIN_USERNAME=admin
# OCTAR_AUTH_DEFAULT_ADMIN_PASSWORD=

# ── Auth Providers ──────────────────────────────────────────────────────────
# OCTAR_AUTH_PROVIDERS_PASSWORD_ENABLED=true
# OCTAR_AUTH_PROVIDERS_PASSWORD_PRIORITY=10
# OCTAR_AUTH_PROVIDERS_API_KEY_ENABLED=true
# OCTAR_AUTH_PROVIDERS_API_KEY_PRIORITY=20
# OCTAR_AUTH_PROVIDERS_API_KEY_PREFIX=flw_live_
# OCTAR_AUTH_PROVIDERS_JWT_ENABLED=true
# OCTAR_AUTH_PROVIDERS_JWT_ACCESS_TOKEN_TTL=900
# OCTAR_AUTH_PROVIDERS_JWT_REFRESH_TOKEN_TTL=604800

# ── Persistence ─────────────────────────────────────────────────────────────
# OCTAR_STORAGE_DATA_DIR=./data
# OCTAR_STORAGE_WAL_FLUSH_INTERVAL=10ms
# OCTAR_STORAGE_WAL_FLUSH_MAX_MESSAGES=1000
# OCTAR_STORAGE_WAL_SEGMENT_MAX_BYTES=536870912
# OCTAR_STORAGE_WAL_SYNC=true
# OCTAR_STORAGE_WAL_SNAPSHOT_INTERVAL=60s
